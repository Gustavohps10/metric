{
  "name": "metric-monorepo",
  "private": true,
  "version": "1.0.0",
  "author": "Gustavo Henrique",
  "type": "module",
  "changeset": "changeset",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --ext .ts,.tsx --ignore-pattern '**/*.d.ts' --ignore-pattern 'node_modules' --ignore-pattern 'dist' --ignore-pattern 'out'",
      "yarn vitest related --run"
    ]
  },
  "workspaces": [
    "src/apps/*",
    "src/packages/*",
    "src/tests/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev:landing-page": "turbo run dev --parallel --filter=@metric-org/landing-page",
    "dev:desktop": "turbo run dev --parallel --filter=@metric-org/desktop",
    "dev": "turbo run dev --parallel",
    "build:landing-page": "turbo run build --filter=@metric-org/landing-page",
    "build:desktop": "turbo run build --filter=@metric-org/desktop",
    "build": "turbo run build",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern '**/*.d.ts' --ignore-pattern 'node_modules' --ignore-pattern 'dist' --ignore-pattern 'out'",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern '**/*.d.ts' --ignore-pattern 'node_modules' --ignore-pattern 'dist' --ignore-pattern 'out' --fix",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky install",
    "postinstall": "husky install",
    "shadcn": "yarn --cwd src/packages/ui dlx shadcn@canary ",
    "puml": "tsup puml.ts --format esm --out-dir dist --clean && node --enable-source-maps dist/puml.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.25.0",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@swc/core": "^1.12.11",
    "@swc/helpers": "^0.5.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "^4.1.4",
    "changeset": "^0.2.6",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "fs-extra": "^11.3.4",
    "globals": "^16.0.0",
    "husky": "^8.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.5.1",
    "msw": "^2.13.3",
    "pako": "^2.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "packageManager": "yarn@4.9.4"
}
