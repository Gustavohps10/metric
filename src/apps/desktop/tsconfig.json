{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@metric-org/IoC": ["../../packages/IoC.ts"],
      "@metric-org/application/*": ["../../packages/application/src/*"],
      "@metric-org/shared/*": ["../../packages/shared/src/*"],
      "@metric-org/adapters/*": ["../../packages/adapters/src/*"],
      "@metric-org/ui/*": ["../../packages/ui/src/*"]
    },
    "types": ["electron-vite/node", "node"]
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/**/*",
    "src/renderer/@types",
    "../../packages/IoC.ts"
  ],
  "references": [
    { "path": "../../packages/application" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/adapters" },
    { "path": "../../packages/ui" }
  ]
}