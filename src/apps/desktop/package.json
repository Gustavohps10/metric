{
  "private": true,
  "name": "@metric-org/desktop",
  "productName": "metric",
  "version": "1.0.0",
  "description": "Metric Desktop App.",
  "main": "./out/main/index.js",
  "type": "module",
  "build": {
    "appId": "com.metric.desktop",
    "productName": "metric",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-setup.${ext}",
    "asar": true,
    "asarUnpack": [
      "out/main/assets/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "yarn build && electron-builder --win",
    "build:mac": "yarn build && electron-builder --mac",
    "build:linux": "yarn build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@metric-org/application": "workspace:*",
    "@metric-org/cross-cutting": "workspace:*",
    "@metric-org/datasource-fake": "workspace:*",
    "@metric-org/infra": "workspace:*",
    "@metric-org/presentation": "workspace:*",
    "@metric-org/redmine-for-tests": "workspace:*",
    "@metric-org/ui": "workspace:*",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.6",
    "@timelapse/redmine-plugin": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.1.7",
    "fake-indexeddb": "^6.2.5",
    "keytar": "^7.9.0",
    "lokijs": "^1.5.12",
    "nuqs": "^2.7.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.29.0",
    "rxdb": "^16.21.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@rollup/plugin-image": "^3.0.3",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lokijs": "^1",
    "@types/node": "^20.17.18",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "electron": "31.0.2",
    "electron-builder": "26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.6",
    "vite": "^6.3.5"
  }
}
