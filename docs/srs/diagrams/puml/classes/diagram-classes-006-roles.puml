@startuml ClassRoles
title TIMELAPSE - Papéis e Permissões (SRS 4.3)
package "Control Plane" {
    class Role {
        +String id
        +String name
        +String[] permissions
    }
    
    enum RoleType {
        owner
        admin
        member
        viewer
    }
}
Role ..> RoleType : type
@enduml
