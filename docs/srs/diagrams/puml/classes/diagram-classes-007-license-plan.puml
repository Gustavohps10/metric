@startuml ClassLicensePlan
title METRIC - Planos de Licença (SRS 3, 4.3)
package "Control Plane" {
    class LicensePlan {
        +String id
        +String name
        +Integer maxMembers
        +String[] features
    }
    
    enum PlanType {
        free
        pro
        enterprise
    }
}
LicensePlan ..> PlanType : plan
@enduml
