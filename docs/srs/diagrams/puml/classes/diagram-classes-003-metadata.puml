@startuml ClassMetadata
title METRIC - Coleção metadata (SRS 6.3)
package "Core Models" {
    class Metadata {
        +String _id
        +Array taskStatuses
        +Array taskPriorities
        +Array activities
        +Array trackStatuses
        +Array participantRoles
        +Array estimationTypes
        +Boolean conflicted
        +Object conflictData
        +DateTime syncedAt
    }
    
    class MetadataItem {
        +String id
        +String name
        +String icon
        +Object colors
    }
}
Metadata *-- MetadataItem : contains
note right of MetadataItem
  colors: badge, background, text, border
end note
@enduml
